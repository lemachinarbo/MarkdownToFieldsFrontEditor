{
  "name": "markdown-front-editor",
  "version": "0.8.5",
  "private": true,
  "type": "module",
  "scripts": {
    "test": "jest",
    "test:watch": "jest --watch",
    "test:e2e": "playwright test --max-failures=1",
    "verify:targeted": "npm test -- tests/document-state-regressions.test.js",
    "verify:e2e:roundtrip": "npm run test:e2e -- tests/e2e/document-save-roundtrip.spec.js",
    "reset:en-home": "sh -c 'CONTENT_ROOT=\"${MFE_CONTENT_ROOT:-../MarkdownTest/public/site/content}\"; cp tests/fixtures/en-home.baseline.md \"$CONTENT_ROOT/en/home.md\"'",
    "reset:es-home": "sh -c 'CONTENT_ROOT=\"${MFE_CONTENT_ROOT:-../MarkdownTest/public/site/content}\"; cp tests/fixtures/es-home.baseline.md \"$CONTENT_ROOT/es/home.md\"'",
    "reset:home-all": "npm run reset:en-home && npm run reset:es-home",
    "build": "vite build",
    "watch": "vite build --watch",
    "dev": "vite build --watch"
  },
  "jest": {
    "testMatch": [
      "**/tests/**/*.test.js"
    ],
    "testPathIgnorePatterns": [
      "/node_modules/",
      "/tests/e2e/"
    ]
  },
  "devDependencies": {
    "@babel/preset-env": "^7.29.0",
    "@playwright/test": "^1.53.2",
    "babel-jest": "^30.2.0",
    "jest": "^30.2.0",
    "jest-environment-jsdom": "^30.2.0",
    "vite": "^5.4.11"
  },
  "dependencies": {
    "@codemirror/commands": "^6.10.3",
    "@codemirror/state": "^6.6.0",
    "@codemirror/view": "^6.41.1",
    "@tiptap/core": "^3.18.0",
    "@tiptap/extension-bullet-list": "^3.19.0",
    "@tiptap/extension-code-block-lowlight": "^3.18.0",
    "@tiptap/extension-image": "^3.19.0",
    "@tiptap/extension-link": "^3.19.0",
    "@tiptap/extension-table": "^3.19.0",
    "@tiptap/extension-table-cell": "^3.19.0",
    "@tiptap/extension-table-header": "^3.19.0",
    "@tiptap/extension-table-row": "^3.19.0",
    "@tiptap/extension-task-item": "^3.19.0",
    "@tiptap/extension-task-list": "^3.19.0",
    "@tiptap/starter-kit": "^3.18.0",
    "lowlight": "^3.1.0",
    "prosemirror-markdown": "^1.13.0",
    "prosemirror-state": "^1.4.4",
    "prosemirror-view": "^1.41.6"
  }
}
